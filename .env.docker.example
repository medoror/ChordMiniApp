# ChordMiniApp Docker Environment Configuration
# Copy this file to .env.docker and fill in your API keys.
#
# Quick start:
#   cp .env.docker.example .env.docker
#   # Fill in the 3 API keys below, then:
#   docker compose -f docker/docker-compose.dev.yml --env-file .env.docker up -d
#
# Everything else (Postgres, backend URLs, storage backend) has working defaults
# in docker-compose.dev.yml — no changes needed.

# ============================================================================
# API KEYS — fill these in
# ============================================================================

# Google Gemini API key (AI chat assistant on the analyze page)
GEMINI_API_KEY=your_gemini_key_here

# YouTube Data API v3 key (YouTube search on the homepage)
NEXT_PUBLIC_YOUTUBE_API_KEY=your_youtube_api_key_here

# Genius API key (lyrics fetching)
GENIUS_API_KEY=your_genius_key_here

# ============================================================================
# OPTIONAL API KEYS
# ============================================================================

# Music.AI API key (legacy lyrics transcription — not needed for normal use)
# MUSIC_AI_API_KEY=your_music_ai_key_here

# ============================================================================
# EVERYTHING BELOW HAS DEFAULTS — only override if you need to
# ============================================================================

# Storage backend: 'postgres' (default) or 'firebase'
STORAGE_BACKEND=postgres

# Postgres credentials (must match docker-compose.dev.yml defaults)
POSTGRES_USER=chordmini
POSTGRES_PASSWORD=chordmini
POSTGRES_DB=chordmini

# Firebase — NOT required when STORAGE_BACKEND=postgres
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
